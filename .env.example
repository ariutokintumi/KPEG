# KPEG API Secrets - TEMPLATE
# Copy this file to .env and fill in your actual keys
# NEVER commit .env (it is gitignored)

# Anthropic API (Claude Vision for encoding)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# fal.ai API (FLUX for decoding/reconstruction)
# Get your key at: https://fal.ai/dashboard/keys
FAL_KEY=YOUR_KEY_ID:YOUR_KEY_SECRET

# Model Selection (switch tiers: testing vs demo)
# Testing tier (cheap):
KPEG_VISION_MODEL=claude-haiku-4-5-20251001
KPEG_IMAGE_MODEL=fal-ai/flux/schnell

# Demo tier (high quality) - uncomment for the hackathon pitch:
# KPEG_VISION_MODEL=claude-sonnet-4-5
# KPEG_IMAGE_MODEL=fal-ai/flux-pro/v1.1

# KPEG Format Settings
KPEG_TARGET_SIZE=1950
KPEG_MAX_SIZE=2048
